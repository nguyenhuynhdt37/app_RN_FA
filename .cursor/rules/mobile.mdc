### 3. Error Handling

```typescript
// ✅ CORRECT - Error codes
try {
  await authService.login(email, password);
} catch (error: unknown) {
  if (error instanceof ApiError) {
    switch (error.code) {
      case 'INVALID_CREDENTIALS':
        showToast(t('errors.invalidCredentials'));
        break;
      case 'ACCOUNT_LOCKED':
        showToast(t('errors.accountLocked'));
        break;
    }
  }
}

// ❌ WRONG - raw message
showToast('Invalid email or password');
```

## Animation Rules

### Spring Physics (MUST USE)

```tsx
import Animated, { 
  useAnimatedStyle, 
  useSharedValue, 
  withSpring 
} from 'react-native-reanimated';

// ✅ CORRECT
const scale = useSharedValue(1);

const animatedStyle = useAnimatedStyle(() => ({
  transform: [{ scale: scale.value }],
}));

const handlePressIn = () => {
  scale.value = withSpring(0.98, { damping: 15, stiffness: 150 });
};

const handlePressOut = () => {
  scale.value = withSpring(1, { damping: 15, stiffness: 150 });
};

// ❌ WRONG - timing-based animation
Animated.timing(scale, {
  toValue: 0.98,
  duration: 200,
  easing: Easing.ease,
}).start();
```

## Image Handling

```typescript
// ✅ CORRECT - CDN images with optimization
import { Image } from 'expo-image';
import { CLOUDINARY_CDN_URL } from '@/src/constants';

interface Props {
  imageUrl: string | null;
  size?: number;
}

export function Avatar({ imageUrl, size = 48 }: Props) {
  const optimizedUrl = imageUrl 
    ? `${CLOUDINARY_CDN_URL}/w_${size},h_${size},c_fill,f_auto/${imageUrl}`
    : null;
    
  return (
    <Image
      source={{ uri: optimizedUrl }}
      style={{ width: size, height: size, borderRadius: size / 2 }}
      contentFit="cover"
    />
  );
}
```

## Performance Checklist

- [ ] Images optimized (WebP, CDN)
- [ ] List items using `FlashList` or optimized FlatList
- [ ] Lazy loading for heavy components
- [ ] No inline styles in render (use StyleSheet)
- [ ] Memoized callbacks with `useCallback`
- [ ] Memoized values with `useMemo`

