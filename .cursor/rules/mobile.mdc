### Component File Limit

```
⚠️ MAXIMUM 150 LINES PER FILE
```

Nếu component vượt quá 150 lines, hãy tách thành:
- Sub-components trong thư mục `components/`
- Logic vào custom hooks trong `src/hooks/`
- Constants vào `src/constants/`

## Coding Standards

### 1. Screen Component Pattern

```tsx
// ✅ CORRECT - Clean screen
export default function HomeScreen() {
  return (
    <Screen>
      <HomeHeader />
      <FeaturedCourses />
      <Categories />
    </Screen>
  );
}

// ❌ WRONG - Logic in screen
export default function HomeScreen() {
  const [data, setData] = useState([]);
  const [loading, setLoading] = useState(true);
  // 200 lines of logic...
}
```

### 2. Feature Component Pattern

```tsx
// ✅ CORRECT - Self-contained feature
export function AuthFeature() {
  const [step, setStep] = useState<AuthStep>('phone');
  
  const handlePhoneSubmit = async (phone: string) => {
    await authService.sendOTP(phone);
    setStep('otp');
  };
  
  return (
    <Animated.View entering={FadeIn} exiting={FadeOut}>
      {step === 'phone' && <PhoneInput onSubmit={handlePhoneSubmit} />}
      {step === 'otp' && <OTPInput phone={phone} />}
    </Animated.View>
  );
}
```

### 3. Type Definitions

```typescript
// ✅ CORRECT - Explicit types
interface User {
  id: string;
  email: string;
  displayName: string;
  avatarUrl: string | null;
  role: 'student' | 'instructor' | 'admin';
  createdAt: Date;
}

// ❌ WRONG - any or implicit any
const user: any = response.data;
```

### 4. State Management (Zustand)

```typescript
// ✅ CORRECT
interface AuthState {
  user: User | null;
  accessToken: string | null;
  isAuthenticated: boolean;
  login: (email: string, password: string) => Promise<void>;
  logout: () => void;
}

export const useAuthStore = create<AuthState>((set) => ({
  user: null,
  accessToken: null,
  isAuthenticated: false,
  
  login: async (email, password) => {
    const response = await authService.login(email, password);
    set({
      user: response.user,
      accessToken: response.accessToken,
      isAuthenticated: true,
    });
  },
  
  logout: () => set({ user: null, accessToken: null, isAuthenticated: false }),
}));

// ❌ WRONG - Multiple useState for auth
const [user, setUser] = useState(null);
const [token, setToken] = useState(null);
const [loading, setLoading] = useState(false);
```

### 5. API Service Pattern

```typescript
// ✅ CORRECT - Centralized API service
import axios from 'axios';
import { useAuthStore } from '../stores/auth.store';

const api = axios.create({
  baseURL: process.env.EXPO_PUBLIC_API_URL,
  timeout: 10000,
});

api.interceptors.request.use((config) => {
  const token = useAuthStore.getState().accessToken;
  if (token) {
    config.headers.Authorization = `Bearer ${token}`;
  }
  return config;
});

export const authService = {
  login: (email: string, password: string) => 
    api.post('/auth/login', { email, password }),
  register: (data: RegisterData) => 
    api.post('/auth/register', data),
  refreshToken: () => 
    api.post('/auth/refresh'),
};
```

