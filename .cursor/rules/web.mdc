# NeuralEarn Web Rules

## Architecture

### Feature-Sliced Design (FSD-Light)

```
web/src/
├── app/[locale]/              # Next.js App Router pages
│   ├── (admin)/              # Admin section
│   │   ├── layout.tsx        # Server layout
│   │   ├── layout-client.tsx # Client layout (sidebar state)
│   │   ├── dashboard/
│   │   ├── users/
│   │   ├── courses/
│   │   └── ...
│   ├── login/
│   │   └── page.tsx
│   └── page.tsx              # Public home
├── features/                   # ALL business logic lives here
│   ├── admin-dashboard/
│   │   ├── components/
│   │   │   ├── DashboardView.tsx  # Root client component
│   │   │   ├── StatCard.tsx
│   │   │   ├── RevenueChart.tsx
│   │   │   └── ...
│   │   └── types.ts
│   ├── admin-users/
│   │   ├── components/
│   │   │   ├── UsersView.tsx
│   │   │   ├── UsersTable.tsx
│   │   │   ├── UserFilters.tsx
│   │   │   └── BanModal.tsx
│   │   └── types.ts
│   └── ...
├── components/
│   ├── admin/
│   │   ├── sidebar.tsx
│   │   └── header.tsx
│   └── ui/                   # Shared UI primitives (future)
├── lib/
│   ├── auth-server.ts         # Server-side auth utilities
│   └── utils.ts              # Utility functions
├── hooks/
├── store/
│   ├── auth-store.ts
│   └── lang-store.ts
├── types/
│   ├── admin.ts
│   └── auth.ts
└── constants/
    └── languages.ts
```

### Golden Rules

> **page.tsx là thin wrapper - KHÔNG chứa logic, KHÔNG chứa JSX phức tạp**
> 
> **Toàn bộ logic, state, components phải nằm trong features/**

```tsx
// ✅ CORRECT - Page is just an import
import { DashboardView } from '@/features/admin-dashboard/components/DashboardView';

export default function DashboardPage() {
  return <DashboardView />;
}

// ❌ WRONG - Logic in page
export default function DashboardPage() {
  const [data, setData] = useState([]);
  // 500 lines of logic...
  return <div>...</div>;
}
```

## Data Fetching Pattern

### NO SWR - Use Server Components + useEffect

```tsx
// ✅ CORRECT - Fetch in Server Component
// app/[locale]/(admin)/dashboard/page.tsx
import { getDashboardStats } from '@/features/admin-dashboard/services/stats';

export default async function DashboardPage() {
  const stats = await getDashboardStats();
  return <DashboardView initialStats={stats} />;
}

// features/admin-dashboard/components/DashboardView.tsx
'use client';

export function DashboardView({ initialStats }: { initialStats: Stats }) {
  const [stats, setStats] = useState(initialStats);
  
  useEffect(() => {
    const controller = new AbortController();
    fetch('/api/admin/stats', { signal: controller.signal })
      .then(r => r.json())
      .then(setStats)
      .catch(e => { if (e.name !== 'AbortError') console.error(e); })
      .finally(() => setLoading(false));
    return () => controller.abort();
  }, []);
  
  return <div>...</div>;
}

// ❌ WRONG - Using SWR or TanStack Query
import useSWR from 'swr';
const { data } = useSWR('/api/admin/stats');
```

### Server Actions for Mutations

```tsx
// ✅ CORRECT - Server Action
'use server';

export async function banUser(userId: string): Promise<{ success: boolean; error?: string }> {
  try {
    await db.user.update({ where: { id: userId }, data: { isBanned: true } });
    revalidatePath('/(admin)/users');
    return { success: true };
  } catch (error) {
    return { success: false, error: 'Failed to ban user' };
  }
}

// ❌ WRONG - API route for mutation
// Don't create /api/admin/users/ban - use server action instead
```

## Component Patterns

### 1. Page Header Pattern

```tsx
import { Plus } from 'lucide-react';

export function PageHeader({ 
  title, 
  subtitle, 
  actionLabel 
}: { 
  title: string; 
  subtitle: string; 
  actionLabel: string; 
}) {
  return (
    <div className="flex items-center justify-between">
      <div>
        <h1 className="text-3xl font-black text-slate-900 dark:text-white tracking-tight">
          {title}
        </h1>
        <p className="text-slate-500 font-semibold mt-1">{subtitle}</p>
      </div>
      <button className="flex items-center gap-2 px-5 py-2.5 bg-emerald-500 text-white font-bold text-sm rounded-2xl hover:bg-emerald-600 shadow-lg shadow-emerald-500/20 transition-all hover:scale-105 active:scale-95">
        <Plus size={16} />
        {actionLabel}
      </button>
    </div>
  );
}
```

### 2. Filter Bar Pattern

```tsx
import { Search } from 'lucide-react';

export function FilterBar({ filters, onChange }: FilterBarProps) {
  return (
    <div className="premium-card">
